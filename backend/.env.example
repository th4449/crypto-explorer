# Database connection string
DATABASE_URL=postgresql://app_user:your_password_here@localhost:5432/crypto_explorer

# Secret key for session signing and token generation
SECRET_KEY=change-this-to-a-random-string

# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# OpenSanctions API key (2,000 requests/month free tier)
# Get a key at https://www.opensanctions.org/api/
OPENSANCTIONS_API_KEY=

# Etherscan API key (optional, used as fallback for blockchain data)
# Get a key at https://etherscan.io/apis
ETHERSCAN_API_KEY=
