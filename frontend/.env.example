# NextAuth configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-this-to-a-random-string-at-least-32-chars

# Database connection (used by NextAuth adapter server-side)
DATABASE_URL=postgresql://app_user:localdevpassword@localhost:5432/crypto_explorer

# Backend API URL (used by browser-side fetch calls)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Email provider (optional for development — links print to terminal)
# In production, set these to a real SMTP server:
# EMAIL_SERVER=smtp://user:pass@smtp.example.com:587
# EMAIL_FROM=noreply@yourdomain.com
