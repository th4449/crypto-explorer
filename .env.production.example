# ============================================================
# Crypto Explorer — Production Environment Variables
# ============================================================
# Copy this file to .env and fill in all required values.
# Variables marked REQUIRED must be set before deployment.
# ============================================================

# --- Database ---

# REQUIRED — PostgreSQL connection string with Apache AGE
# Format: postgresql://user:password@host:port/database
DB_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
DATABASE_URL=postgresql://app_user:${DB_PASSWORD}@db:5432/crypto_explorer

# --- Authentication ---

# REQUIRED — Random string for signing session tokens (min 32 chars)
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# REQUIRED — Random string for NextAuth session encryption (min 32 chars)
# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# REQUIRED — Full URL where the frontend is hosted (no trailing slash)
NEXTAUTH_URL=https://your-domain.com

# --- API Configuration ---

# REQUIRED — Full URL where the backend API is hosted (no trailing slash)
NEXT_PUBLIC_API_URL=https://api.your-domain.com

# REQUIRED — Comma-separated list of frontend origins allowed by CORS
# Must match the exact origin(s) of your frontend deployment
CORS_ORIGINS=https://your-domain.com

# --- Email (Magic Link Login) ---

# REQUIRED for production — SMTP connection string
# Format: smtp://user:password@smtp.provider.com:587
# Common providers:
#   Resend:    smtp://resend:re_xxxx@smtp.resend.com:587
#   SendGrid:  smtp://apikey:SG.xxxx@smtp.sendgrid.net:587
#   Mailgun:   smtp://postmaster@mg.domain.com:password@smtp.mailgun.org:587
EMAIL_SERVER=smtp://user:password@smtp.example.com:587

# From address for magic link emails
EMAIL_FROM=noreply@your-domain.com

# --- External API Keys ---

# OpenSanctions API key (2,000 requests/month free tier)
# Get one at: https://www.opensanctions.org/api/
OPENSANCTIONS_API_KEY=

# Etherscan API key (optional, fallback for blockchain data)
# Get one at: https://etherscan.io/apis
ETHERSCAN_API_KEY=

# --- Monitoring ---

# Sentry DSN for error tracking (free tier: 5K events/month)
# Create a project at: https://sentry.io
# Backend DSN (FastAPI)
SENTRY_DSN=
# Frontend DSN (Next.js) — must be NEXT_PUBLIC_ prefixed for client-side
NEXT_PUBLIC_SENTRY_DSN=

# Environment label shown in Sentry dashboard
ENVIRONMENT=production

# --- Backups ---

# S3-compatible bucket for database backups
# Leave empty to store backups locally only
# Examples:
#   AWS S3:       s3://my-bucket-name
#   Cloudflare R2: s3://my-r2-bucket (set AWS_ENDPOINT_URL too)
#   Backblaze B2:  s3://my-b2-bucket (set AWS_ENDPOINT_URL too)
BACKUP_BUCKET=

# For non-AWS S3-compatible storage, set the endpoint URL
# AWS_ENDPOINT_URL=https://xxxx.r2.cloudflarestorage.com

# S3 credentials (or use instance roles/service accounts)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# How many days to keep backups (default: 30)
BACKUP_RETENTION_DAYS=30

# --- Uptime Monitoring ---

# Health endpoint URL for the uptime check script
HEALTH_URL=https://api.your-domain.com/health

# Email address for downtime alerts
ALERT_EMAIL=admin@your-domain.com

# --- Notes ---
#
# After setting these values:
#
# 1. Never commit the .env file to version control
# 2. Rotate SECRET_KEY and NEXTAUTH_SECRET if they are ever exposed
# 3. DB_PASSWORD should be at least 20 characters with mixed case,
#    digits, and symbols
# 4. For Railway/Render, set these in the platform's environment
#    variable UI rather than in a file
